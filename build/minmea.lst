 224:SynaptiX_FDK/components/gps/minmea.h **** /**
 225:SynaptiX_FDK/components/gps/minmea.h ****  * Scanf-like processor for NMEA sentences. Supports the following formats:
 226:SynaptiX_FDK/components/gps/minmea.h ****  * c - single character (char *)
 227:SynaptiX_FDK/components/gps/minmea.h ****  * d - direction, returned as 1/-1, default 0 (int *)
 228:SynaptiX_FDK/components/gps/minmea.h ****  * f - fractional, returned as value + scale (struct minmea_float *)
 229:SynaptiX_FDK/components/gps/minmea.h ****  * i - decimal, default zero (int *)
 230:SynaptiX_FDK/components/gps/minmea.h ****  * s - string (char *)
