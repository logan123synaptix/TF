 232:SynaptiX_FDK/components/gps/minmea.h ****  * D - date (struct minmea_date *)
 233:SynaptiX_FDK/components/gps/minmea.h ****  * T - time stamp (struct minmea_time *)
 234:SynaptiX_FDK/components/gps/minmea.h ****  * _ - ignore this field
 235:SynaptiX_FDK/components/gps/minmea.h ****  * ; - following fields are optional
