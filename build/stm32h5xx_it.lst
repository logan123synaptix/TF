 131:Core/Src/stm32h5xx_it.c **** 
 132:Core/Src/stm32h5xx_it.c **** /**
 133:Core/Src/stm32h5xx_it.c ****   * @brief This function handles Hard fault interrupt.
 134:Core/Src/stm32h5xx_it.c ****   *
 135:Core/Src/stm32h5xx_it.c ****   * DEBUG: naked trampoline for the "app hangs after bootloader jump" investigation.
 136:Core/Src/stm32h5xx_it.c ****   * IMPORTANT: a naked function's body must contain ONLY an asm block -- no comments,
 137:Core/Src/stm32h5xx_it.c ****   * no USER CODE markers, no other C statements. GCC only warns (doesn't error) if this
 138:Core/Src/stm32h5xx_it.c ****   * rule is violated, and may silently inject its own prologue/epilogue in that case,
 139:Core/Src/stm32h5xx_it.c ****   * which would corrupt r0/lr before HardFault_LogAndHang ever runs. That would explain
 140:Core/Src/stm32h5xx_it.c ****   * a FAULT log never appearing even on a genuine fault, so keep this function's body
 141:Core/Src/stm32h5xx_it.c ****   * exactly as minimal as it is below if editing it again.
 142:Core/Src/stm32h5xx_it.c ****   *
 143:Core/Src/stm32h5xx_it.c ****   * On fault entry, LR holds EXC_RETURN, whose bit 2 tells us whether the CPU was using
 144:Core/Src/stm32h5xx_it.c ****   * MSP or PSP at the time of the fault. This project never uses PSP (no RTOS), so this
 145:Core/Src/stm32h5xx_it.c ****   * will always resolve to MSP, but the check is kept in case that ever changes.
 146:Core/Src/stm32h5xx_it.c ****   */
 147:Core/Src/stm32h5xx_it.c **** __attribute__((naked)) void HardFault_Handler(void)
 148:Core/Src/stm32h5xx_it.c **** {
