5757:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the SYNCDIV[2:0] bits according to Prescaler value */
5758:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the SYNCSRC[1:0] bits according to Source value */
5759:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the SYNCSPOL bit according to Polarity value */
5760:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   value = (pInit->Prescaler | pInit->Source | pInit->Polarity);
5761:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the RELOAD[15:0] bits according to ReloadValue value */
5762:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   value |= pInit->ReloadValue;
5763:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Set the FELIM[7:0] bits according to ErrorLimitValue value */
