5753:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   /* Before configuration, reset CRS registers to their default values*/
5754:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   __HAL_RCC_CRS_FORCE_RESET();
5755:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_rcc_ex.c ****   __HAL_RCC_CRS_RELEASE_RESET();
