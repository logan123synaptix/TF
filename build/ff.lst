ARM GAS  C:\Users\LENOVO\AppData\Local\Temp\ccokA7qo.s 			page 29


1339:SynaptiX_FDK/services/fatfs/ff.c **** 				if (++val >= fs->n_fatent - 2) {	/* Next cluster (with wrap-around) */
1340:SynaptiX_FDK/services/fatfs/ff.c **** 					val = 0; bm = 0; i = SS(fs);
1341:SynaptiX_FDK/services/fatfs/ff.c **** 				}
1342:SynaptiX_FDK/services/fatfs/ff.c **** 				if (bv == 0) {	/* Is it a free cluster? */
1343:SynaptiX_FDK/services/fatfs/ff.c **** 					if (++ctr == ncl) return scl + 2;	/* Check if run length is sufficient for required */
1344:SynaptiX_FDK/services/fatfs/ff.c **** 				} else {
1345:SynaptiX_FDK/services/fatfs/ff.c **** 					scl = val; ctr = 0;		/* Encountered a cluster in-use, restart to scan */
1346:SynaptiX_FDK/services/fatfs/ff.c **** 				}
1347:SynaptiX_FDK/services/fatfs/ff.c **** 				if (val == clst) return 0;	/* All cluster scanned? */
