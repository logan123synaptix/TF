3749:SynaptiX_FDK/services/fatfs/ff.c **** 
3750:SynaptiX_FDK/services/fatfs/ff.c **** 
3751:SynaptiX_FDK/services/fatfs/ff.c **** 	/* Get volume ID (logical drive number) */
3752:SynaptiX_FDK/services/fatfs/ff.c **** 	vol = get_ldnumber(&rp);
3753:SynaptiX_FDK/services/fatfs/ff.c **** 	if (vol < 0) return FR_INVALID_DRIVE;
3754:SynaptiX_FDK/services/fatfs/ff.c **** 
3755:SynaptiX_FDK/services/fatfs/ff.c **** 	cfs = FatFs[vol];			/* Pointer to the filesystem object of the volume */
3756:SynaptiX_FDK/services/fatfs/ff.c **** 	if (cfs) {					/* Unregister current filesystem object */
3757:SynaptiX_FDK/services/fatfs/ff.c **** 		FatFs[vol] = 0;
3758:SynaptiX_FDK/services/fatfs/ff.c **** #if FF_FS_LOCK					/* Clear file lock semaphores correspond to this volume */
3759:SynaptiX_FDK/services/fatfs/ff.c **** 		clear_share(cfs);
3760:SynaptiX_FDK/services/fatfs/ff.c **** #endif
3761:SynaptiX_FDK/services/fatfs/ff.c **** #if FF_FS_REENTRANT				/* Discard mutex of the current volume */
3762:SynaptiX_FDK/services/fatfs/ff.c **** 		ff_mutex_delete(vol);
3763:SynaptiX_FDK/services/fatfs/ff.c **** #endif
3764:SynaptiX_FDK/services/fatfs/ff.c **** 		cfs->fs_type = 0;		/* Invalidate the filesystem object to be unregistered */
3765:SynaptiX_FDK/services/fatfs/ff.c **** 	}
3766:SynaptiX_FDK/services/fatfs/ff.c **** 
3767:SynaptiX_FDK/services/fatfs/ff.c **** 	if (fs) {					/* Register new filesystem object */
3768:SynaptiX_FDK/services/fatfs/ff.c **** 		fs->pdrv = LD2PD(vol);	/* Volume hosting physical drive */
3769:SynaptiX_FDK/services/fatfs/ff.c **** #if FF_FS_REENTRANT				/* Create a volume mutex */
3770:SynaptiX_FDK/services/fatfs/ff.c **** 		fs->ldrv = (BYTE)vol;	/* Owner volume ID */
3771:SynaptiX_FDK/services/fatfs/ff.c **** 		if (!ff_mutex_create(vol)) return FR_INT_ERR;
3772:SynaptiX_FDK/services/fatfs/ff.c **** #if FF_FS_LOCK
3773:SynaptiX_FDK/services/fatfs/ff.c **** 		if (SysLock == 0) {		/* Create a system mutex if needed */
3774:SynaptiX_FDK/services/fatfs/ff.c **** 			if (!ff_mutex_create(FF_VOLUMES)) {
3775:SynaptiX_FDK/services/fatfs/ff.c **** 				ff_mutex_delete(vol);
3776:SynaptiX_FDK/services/fatfs/ff.c **** 				return FR_INT_ERR;
3777:SynaptiX_FDK/services/fatfs/ff.c **** 			}
3778:SynaptiX_FDK/services/fatfs/ff.c **** 			SysLock = 1;		/* System mutex is ready */
3779:SynaptiX_FDK/services/fatfs/ff.c **** 		}
3780:SynaptiX_FDK/services/fatfs/ff.c **** #endif
3781:SynaptiX_FDK/services/fatfs/ff.c **** #endif
3782:SynaptiX_FDK/services/fatfs/ff.c **** 		fs->fs_type = 0;		/* Invalidate the new filesystem object */
3783:SynaptiX_FDK/services/fatfs/ff.c **** 		FatFs[vol] = fs;		/* Register it */
3784:SynaptiX_FDK/services/fatfs/ff.c **** 	}
3785:SynaptiX_FDK/services/fatfs/ff.c **** 
3786:SynaptiX_FDK/services/fatfs/ff.c **** 	if (opt == 0) return FR_OK;	/* Do not mount now, it will be mounted in subsequent file functions *
3787:SynaptiX_FDK/services/fatfs/ff.c **** 
3788:SynaptiX_FDK/services/fatfs/ff.c **** 	res = mount_volume(&path, &fs, 0);	/* Force mounted the volume in this function */
3789:SynaptiX_FDK/services/fatfs/ff.c **** 	LEAVE_FF(fs, res);
3790:SynaptiX_FDK/services/fatfs/ff.c **** }
