1330:SynaptiX_FDK/services/fatfs/ff.c **** 	clst -= 2;	/* The first bit in the bitmap corresponds to cluster #2 */
1331:SynaptiX_FDK/services/fatfs/ff.c **** 	if (clst >= fs->n_fatent - 2) clst = 0;
1332:SynaptiX_FDK/services/fatfs/ff.c **** 	scl = val = clst; ctr = 0;
