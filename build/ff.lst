3739:SynaptiX_FDK/services/fatfs/ff.c **** FRESULT f_mount (
3740:SynaptiX_FDK/services/fatfs/ff.c **** 	FATFS* fs,			/* Pointer to the filesystem object to be registered (NULL:unmount)*/
3741:SynaptiX_FDK/services/fatfs/ff.c **** 	const TCHAR* path,	/* Logical drive number to be mounted/unmounted */
3742:SynaptiX_FDK/services/fatfs/ff.c **** 	BYTE opt			/* Mount option: 0=Do not mount (delayed mount), 1=Mount immediately */
3743:SynaptiX_FDK/services/fatfs/ff.c **** )
3744:SynaptiX_FDK/services/fatfs/ff.c **** {
3745:SynaptiX_FDK/services/fatfs/ff.c **** 	FATFS *cfs;
