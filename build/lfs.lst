 192:SynaptiX_FDK/services/littlefs/lfs.c **** #ifndef LFS_READONLY
 193:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_flush(lfs_t *lfs,
 194:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_cache_t *pcache, lfs_cache_t *rcache, bool validate) {
 195:SynaptiX_FDK/services/littlefs/lfs.c ****     if (pcache->block != LFS_BLOCK_NULL && pcache->block != LFS_BLOCK_INLINE) {
 196:SynaptiX_FDK/services/littlefs/lfs.c ****         LFS_ASSERT(pcache->block < lfs->block_count);
 197:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_size_t diff = lfs_alignup(pcache->size, lfs->cfg->prog_size);
