3762:SynaptiX_FDK/services/littlefs/lfs.c **** 
3763:SynaptiX_FDK/services/littlefs/lfs.c ****     // update pos
3764:SynaptiX_FDK/services/littlefs/lfs.c ****     file->pos = npos;
