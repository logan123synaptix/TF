  87:SynaptiX_FDK/services/littlefs/lfs.c ****             // rcache takes priority
  88:SynaptiX_FDK/services/littlefs/lfs.c ****             diff = lfs_min(diff, rcache->off-off);
  89:SynaptiX_FDK/services/littlefs/lfs.c ****         }
  90:SynaptiX_FDK/services/littlefs/lfs.c **** 
  91:SynaptiX_FDK/services/littlefs/lfs.c ****         if (size >= hint && off % lfs->cfg->read_size == 0 &&
  92:SynaptiX_FDK/services/littlefs/lfs.c ****                 size >= lfs->cfg->read_size) {
  93:SynaptiX_FDK/services/littlefs/lfs.c ****             // bypass cache?
