 228:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_sync(lfs_t *lfs,
 229:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_cache_t *pcache, lfs_cache_t *rcache, bool validate) {
 230:SynaptiX_FDK/services/littlefs/lfs.c ****     lfs_cache_drop(lfs, rcache);
 231:SynaptiX_FDK/services/littlefs/lfs.c **** 
 232:SynaptiX_FDK/services/littlefs/lfs.c ****     int err = lfs_bd_flush(lfs, pcache, rcache, validate);
