 128:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_cmp(lfs_t *lfs,
 129:SynaptiX_FDK/services/littlefs/lfs.c ****         const lfs_cache_t *pcache, lfs_cache_t *rcache, lfs_size_t hint,
 130:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_block_t block, lfs_off_t off,
 131:SynaptiX_FDK/services/littlefs/lfs.c ****         const void *buffer, lfs_size_t size) {
 132:SynaptiX_FDK/services/littlefs/lfs.c ****     const uint8_t *data = buffer;
