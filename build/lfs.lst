  48:SynaptiX_FDK/services/littlefs/lfs.c ****     uint8_t *data = buffer;
  49:SynaptiX_FDK/services/littlefs/lfs.c ****     if (off+size > lfs->cfg->block_size
  50:SynaptiX_FDK/services/littlefs/lfs.c ****             || (lfs->block_count && block >= lfs->block_count)) {
  51:SynaptiX_FDK/services/littlefs/lfs.c ****         return LFS_ERR_CORRUPT;
  52:SynaptiX_FDK/services/littlefs/lfs.c ****     }
  53:SynaptiX_FDK/services/littlefs/lfs.c **** 
  54:SynaptiX_FDK/services/littlefs/lfs.c ****     while (size > 0) {
  55:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_size_t diff = size;
  56:SynaptiX_FDK/services/littlefs/lfs.c **** 
  57:SynaptiX_FDK/services/littlefs/lfs.c ****         if (pcache && block == pcache->block &&
  58:SynaptiX_FDK/services/littlefs/lfs.c ****                 off < pcache->off + pcache->size) {
  59:SynaptiX_FDK/services/littlefs/lfs.c ****             if (off >= pcache->off) {
  60:SynaptiX_FDK/services/littlefs/lfs.c ****                 // is already in pcache?
  61:SynaptiX_FDK/services/littlefs/lfs.c ****                 diff = lfs_min(diff, pcache->size - (off-pcache->off));
  62:SynaptiX_FDK/services/littlefs/lfs.c ****                 memcpy(data, &pcache->buffer[off-pcache->off], diff);
  63:SynaptiX_FDK/services/littlefs/lfs.c **** 
  64:SynaptiX_FDK/services/littlefs/lfs.c ****                 data += diff;
  65:SynaptiX_FDK/services/littlefs/lfs.c ****                 off += diff;
  66:SynaptiX_FDK/services/littlefs/lfs.c ****                 size -= diff;
  67:SynaptiX_FDK/services/littlefs/lfs.c ****                 continue;
  68:SynaptiX_FDK/services/littlefs/lfs.c ****             }
  69:SynaptiX_FDK/services/littlefs/lfs.c **** 
  70:SynaptiX_FDK/services/littlefs/lfs.c ****             // pcache takes priority
  71:SynaptiX_FDK/services/littlefs/lfs.c ****             diff = lfs_min(diff, pcache->off-off);
  72:SynaptiX_FDK/services/littlefs/lfs.c ****         }
  73:SynaptiX_FDK/services/littlefs/lfs.c **** 
  74:SynaptiX_FDK/services/littlefs/lfs.c ****         if (block == rcache->block &&
  75:SynaptiX_FDK/services/littlefs/lfs.c ****                 off < rcache->off + rcache->size) {
  76:SynaptiX_FDK/services/littlefs/lfs.c ****             if (off >= rcache->off) {
