 199:SynaptiX_FDK/services/littlefs/lfs.c ****                 pcache->off, pcache->buffer, diff);
 200:SynaptiX_FDK/services/littlefs/lfs.c ****         LFS_ASSERT(err <= 0);
ARM GAS  C:\Users\LENOVO\AppData\Local\Temp\ccUMIPmL.s 			page 5


 201:SynaptiX_FDK/services/littlefs/lfs.c ****         if (err) {
