 100:SynaptiX_FDK/services/littlefs/lfs.c **** 
 101:SynaptiX_FDK/services/littlefs/lfs.c ****             data += diff;
 102:SynaptiX_FDK/services/littlefs/lfs.c ****             off += diff;
 103:SynaptiX_FDK/services/littlefs/lfs.c ****             size -= diff;
 104:SynaptiX_FDK/services/littlefs/lfs.c ****             continue;
 105:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 106:SynaptiX_FDK/services/littlefs/lfs.c **** 
 107:SynaptiX_FDK/services/littlefs/lfs.c ****         // load to cache, first condition can no longer fail
 108:SynaptiX_FDK/services/littlefs/lfs.c ****         LFS_ASSERT(!lfs->block_count || block < lfs->block_count);
 109:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->block = block;
 110:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->off = lfs_aligndown(off, lfs->cfg->read_size);
 111:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->size = lfs_min(
 112:SynaptiX_FDK/services/littlefs/lfs.c ****                 lfs_min(
 113:SynaptiX_FDK/services/littlefs/lfs.c ****                     lfs_alignup(off+hint, lfs->cfg->read_size),
 114:SynaptiX_FDK/services/littlefs/lfs.c ****                     lfs->cfg->block_size)
 115:SynaptiX_FDK/services/littlefs/lfs.c ****                 - rcache->off,
 116:SynaptiX_FDK/services/littlefs/lfs.c ****                 lfs->cfg->cache_size);
 117:SynaptiX_FDK/services/littlefs/lfs.c ****         int err = lfs->cfg->read(lfs->cfg, rcache->block,
 118:SynaptiX_FDK/services/littlefs/lfs.c ****                 rcache->off, rcache->buffer, rcache->size);
 119:SynaptiX_FDK/services/littlefs/lfs.c ****         LFS_ASSERT(err <= 0);
 120:SynaptiX_FDK/services/littlefs/lfs.c ****         if (err) {
 121:SynaptiX_FDK/services/littlefs/lfs.c ****             return err;
 122:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 123:SynaptiX_FDK/services/littlefs/lfs.c ****     }
 124:SynaptiX_FDK/services/littlefs/lfs.c **** 
 125:SynaptiX_FDK/services/littlefs/lfs.c ****     return 0;
 126:SynaptiX_FDK/services/littlefs/lfs.c **** }
