  30:SynaptiX_FDK/services/littlefs/lfs.c **** /// Caching block device operations ///
  31:SynaptiX_FDK/services/littlefs/lfs.c **** 
  32:SynaptiX_FDK/services/littlefs/lfs.c **** static inline void lfs_cache_drop(lfs_t *lfs, lfs_cache_t *rcache) {
  33:SynaptiX_FDK/services/littlefs/lfs.c ****     // do not zero, cheaper if cache is readonly or only going to be
  34:SynaptiX_FDK/services/littlefs/lfs.c ****     // written with identical data (during relocates)
  35:SynaptiX_FDK/services/littlefs/lfs.c ****     (void)lfs;
  36:SynaptiX_FDK/services/littlefs/lfs.c ****     rcache->block = LFS_BLOCK_NULL;
  37:SynaptiX_FDK/services/littlefs/lfs.c **** }
  38:SynaptiX_FDK/services/littlefs/lfs.c **** 
  39:SynaptiX_FDK/services/littlefs/lfs.c **** static inline void lfs_cache_zero(lfs_t *lfs, lfs_cache_t *pcache) {
  40:SynaptiX_FDK/services/littlefs/lfs.c ****     // zero to avoid information leak
  41:SynaptiX_FDK/services/littlefs/lfs.c ****     memset(pcache->buffer, 0xff, lfs->cfg->cache_size);
  42:SynaptiX_FDK/services/littlefs/lfs.c ****     pcache->block = LFS_BLOCK_NULL;
  43:SynaptiX_FDK/services/littlefs/lfs.c **** }
  44:SynaptiX_FDK/services/littlefs/lfs.c **** 
  45:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_read(lfs_t *lfs,
  46:SynaptiX_FDK/services/littlefs/lfs.c ****         const lfs_cache_t *pcache, lfs_cache_t *rcache, lfs_size_t hint,
  47:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_block_t block, lfs_off_t off,
  48:SynaptiX_FDK/services/littlefs/lfs.c ****         void *buffer, lfs_size_t size) {
  49:SynaptiX_FDK/services/littlefs/lfs.c ****     uint8_t *data = buffer;
  50:SynaptiX_FDK/services/littlefs/lfs.c ****     if (off+size > lfs->cfg->block_size
  51:SynaptiX_FDK/services/littlefs/lfs.c ****             || (lfs->block_count && block >= lfs->block_count)) {
  52:SynaptiX_FDK/services/littlefs/lfs.c ****         return LFS_ERR_CORRUPT;
  53:SynaptiX_FDK/services/littlefs/lfs.c ****     }
  54:SynaptiX_FDK/services/littlefs/lfs.c **** 
  55:SynaptiX_FDK/services/littlefs/lfs.c ****     // DEBUG: temporary loop counter to detect infinite loop in this function.
  56:SynaptiX_FDK/services/littlefs/lfs.c ****     uint32_t dbg_bd_read_iters = 0;
  57:SynaptiX_FDK/services/littlefs/lfs.c **** 
  58:SynaptiX_FDK/services/littlefs/lfs.c ****     while (size > 0) {
  59:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_size_t diff = size;
  60:SynaptiX_FDK/services/littlefs/lfs.c **** 
  61:SynaptiX_FDK/services/littlefs/lfs.c ****         // DEBUG: temporary trace - only log once this loop runs abnormally long
  62:SynaptiX_FDK/services/littlefs/lfs.c ****         // (normal iteration count observed so far tops out around 4), to avoid
  63:SynaptiX_FDK/services/littlefs/lfs.c ****         // flooding UART and to make sure the log right before a real hang isn't lost.
  64:SynaptiX_FDK/services/littlefs/lfs.c ****         dbg_bd_read_iters++;
  65:SynaptiX_FDK/services/littlefs/lfs.c ****         if (dbg_bd_read_iters == 6 || dbg_bd_read_iters % 50 == 0) {
  66:SynaptiX_FDK/services/littlefs/lfs.c ****             log_error("LFS_DBG",
  67:SynaptiX_FDK/services/littlefs/lfs.c ****                 "bd_read: SUSPICIOUS iter=%lu block=%lu off=%lu size=%lu | rcache.block=%lu rcache.
  68:SynaptiX_FDK/services/littlefs/lfs.c ****                 (unsigned long)dbg_bd_read_iters, (unsigned long)block, (unsigned long)off, (unsign
  69:SynaptiX_FDK/services/littlefs/lfs.c ****                 (unsigned long)rcache->block, (unsigned long)rcache->off, (unsigned long)rcache->si
  70:SynaptiX_FDK/services/littlefs/lfs.c ****                 (void*)pcache);
  71:SynaptiX_FDK/services/littlefs/lfs.c ****         }
  72:SynaptiX_FDK/services/littlefs/lfs.c **** 
  73:SynaptiX_FDK/services/littlefs/lfs.c ****         if (pcache && block == pcache->block &&
  74:SynaptiX_FDK/services/littlefs/lfs.c ****                 off < pcache->off + pcache->size) {
  75:SynaptiX_FDK/services/littlefs/lfs.c ****             if (off >= pcache->off) {
  76:SynaptiX_FDK/services/littlefs/lfs.c ****                 // is already in pcache?
  77:SynaptiX_FDK/services/littlefs/lfs.c ****                 diff = lfs_min(diff, pcache->size - (off-pcache->off));
  78:SynaptiX_FDK/services/littlefs/lfs.c ****                 memcpy(data, &pcache->buffer[off-pcache->off], diff);
  79:SynaptiX_FDK/services/littlefs/lfs.c **** 
  80:SynaptiX_FDK/services/littlefs/lfs.c ****                 data += diff;
  81:SynaptiX_FDK/services/littlefs/lfs.c ****                 off += diff;
  82:SynaptiX_FDK/services/littlefs/lfs.c ****                 size -= diff;
  83:SynaptiX_FDK/services/littlefs/lfs.c ****                 continue;
  84:SynaptiX_FDK/services/littlefs/lfs.c ****             }
  85:SynaptiX_FDK/services/littlefs/lfs.c **** 
  86:SynaptiX_FDK/services/littlefs/lfs.c ****             // pcache takes priority
ARM GAS  C:\Users\LENOVO\AppData\Local\Temp\ccUMIPmL.s 			page 3


  87:SynaptiX_FDK/services/littlefs/lfs.c ****             diff = lfs_min(diff, pcache->off-off);
  88:SynaptiX_FDK/services/littlefs/lfs.c ****         }
  89:SynaptiX_FDK/services/littlefs/lfs.c **** 
  90:SynaptiX_FDK/services/littlefs/lfs.c ****         if (block == rcache->block &&
  91:SynaptiX_FDK/services/littlefs/lfs.c ****                 off < rcache->off + rcache->size) {
  92:SynaptiX_FDK/services/littlefs/lfs.c ****             if (off >= rcache->off) {
  93:SynaptiX_FDK/services/littlefs/lfs.c ****                 // is already in rcache?
  94:SynaptiX_FDK/services/littlefs/lfs.c ****                 diff = lfs_min(diff, rcache->size - (off-rcache->off));
  95:SynaptiX_FDK/services/littlefs/lfs.c ****                 memcpy(data, &rcache->buffer[off-rcache->off], diff);
  96:SynaptiX_FDK/services/littlefs/lfs.c **** 
  97:SynaptiX_FDK/services/littlefs/lfs.c ****                 data += diff;
  98:SynaptiX_FDK/services/littlefs/lfs.c ****                 off += diff;
  99:SynaptiX_FDK/services/littlefs/lfs.c ****                 size -= diff;
 100:SynaptiX_FDK/services/littlefs/lfs.c ****                 continue;
 101:SynaptiX_FDK/services/littlefs/lfs.c ****             }
 102:SynaptiX_FDK/services/littlefs/lfs.c **** 
 103:SynaptiX_FDK/services/littlefs/lfs.c ****             // rcache takes priority
 104:SynaptiX_FDK/services/littlefs/lfs.c ****             diff = lfs_min(diff, rcache->off-off);
 105:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 106:SynaptiX_FDK/services/littlefs/lfs.c **** 
 107:SynaptiX_FDK/services/littlefs/lfs.c ****         if (size >= hint && off % lfs->cfg->read_size == 0 &&
 108:SynaptiX_FDK/services/littlefs/lfs.c ****                 size >= lfs->cfg->read_size) {
 109:SynaptiX_FDK/services/littlefs/lfs.c ****             // bypass cache?
 110:SynaptiX_FDK/services/littlefs/lfs.c ****             diff = lfs_aligndown(diff, lfs->cfg->read_size);
 111:SynaptiX_FDK/services/littlefs/lfs.c ****             int err = lfs->cfg->read(lfs->cfg, block, off, data, diff);
 112:SynaptiX_FDK/services/littlefs/lfs.c ****             LFS_ASSERT(err <= 0);
 113:SynaptiX_FDK/services/littlefs/lfs.c ****             if (err) {
 114:SynaptiX_FDK/services/littlefs/lfs.c ****                 return err;
 115:SynaptiX_FDK/services/littlefs/lfs.c ****             }
 116:SynaptiX_FDK/services/littlefs/lfs.c **** 
 117:SynaptiX_FDK/services/littlefs/lfs.c ****             data += diff;
 118:SynaptiX_FDK/services/littlefs/lfs.c ****             off += diff;
 119:SynaptiX_FDK/services/littlefs/lfs.c ****             size -= diff;
 120:SynaptiX_FDK/services/littlefs/lfs.c ****             continue;
 121:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 122:SynaptiX_FDK/services/littlefs/lfs.c **** 
 123:SynaptiX_FDK/services/littlefs/lfs.c ****         // load to cache, first condition can no longer fail
 124:SynaptiX_FDK/services/littlefs/lfs.c ****         LFS_ASSERT(!lfs->block_count || block < lfs->block_count);
 125:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->block = block;
 126:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->off = lfs_aligndown(off, lfs->cfg->read_size);
 127:SynaptiX_FDK/services/littlefs/lfs.c ****         rcache->size = lfs_min(
 128:SynaptiX_FDK/services/littlefs/lfs.c ****                 lfs_min(
 129:SynaptiX_FDK/services/littlefs/lfs.c ****                     lfs_alignup(off+hint, lfs->cfg->read_size),
 130:SynaptiX_FDK/services/littlefs/lfs.c ****                     lfs->cfg->block_size)
 131:SynaptiX_FDK/services/littlefs/lfs.c ****                 - rcache->off,
 132:SynaptiX_FDK/services/littlefs/lfs.c ****                 lfs->cfg->cache_size);
 133:SynaptiX_FDK/services/littlefs/lfs.c ****         int err = lfs->cfg->read(lfs->cfg, rcache->block,
 134:SynaptiX_FDK/services/littlefs/lfs.c ****                 rcache->off, rcache->buffer, rcache->size);
 135:SynaptiX_FDK/services/littlefs/lfs.c ****         LFS_ASSERT(err <= 0);
 136:SynaptiX_FDK/services/littlefs/lfs.c ****         if (err) {
 137:SynaptiX_FDK/services/littlefs/lfs.c ****             return err;
 138:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 139:SynaptiX_FDK/services/littlefs/lfs.c ****     }
 140:SynaptiX_FDK/services/littlefs/lfs.c **** 
 141:SynaptiX_FDK/services/littlefs/lfs.c ****     return 0;
 142:SynaptiX_FDK/services/littlefs/lfs.c **** }
