 203:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 204:SynaptiX_FDK/services/littlefs/lfs.c **** 
 205:SynaptiX_FDK/services/littlefs/lfs.c ****         if (validate) {
 206:SynaptiX_FDK/services/littlefs/lfs.c ****             // check data on disk
 207:SynaptiX_FDK/services/littlefs/lfs.c ****             lfs_cache_drop(lfs, rcache);
