 144:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_cmp(lfs_t *lfs,
 145:SynaptiX_FDK/services/littlefs/lfs.c ****         const lfs_cache_t *pcache, lfs_cache_t *rcache, lfs_size_t hint,
 146:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_block_t block, lfs_off_t off,
 147:SynaptiX_FDK/services/littlefs/lfs.c ****         const void *buffer, lfs_size_t size) {
 148:SynaptiX_FDK/services/littlefs/lfs.c ****     const uint8_t *data = buffer;
 149:SynaptiX_FDK/services/littlefs/lfs.c ****     lfs_size_t diff = 0;
 150:SynaptiX_FDK/services/littlefs/lfs.c **** 
 151:SynaptiX_FDK/services/littlefs/lfs.c ****     for (lfs_off_t i = 0; i < size; i += diff) {
 152:SynaptiX_FDK/services/littlefs/lfs.c ****         uint8_t dat[8];
 153:SynaptiX_FDK/services/littlefs/lfs.c **** 
 154:SynaptiX_FDK/services/littlefs/lfs.c ****         diff = lfs_min(size-i, sizeof(dat));
 155:SynaptiX_FDK/services/littlefs/lfs.c ****         int err = lfs_bd_read(lfs,
 156:SynaptiX_FDK/services/littlefs/lfs.c ****                 pcache, rcache, hint-i,
 157:SynaptiX_FDK/services/littlefs/lfs.c ****                 block, off+i, &dat, diff);
 158:SynaptiX_FDK/services/littlefs/lfs.c ****         if (err) {
 159:SynaptiX_FDK/services/littlefs/lfs.c ****             return err;
 160:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 161:SynaptiX_FDK/services/littlefs/lfs.c **** 
 162:SynaptiX_FDK/services/littlefs/lfs.c ****         int res = memcmp(dat, data + i, diff);
 163:SynaptiX_FDK/services/littlefs/lfs.c ****         if (res) {
 164:SynaptiX_FDK/services/littlefs/lfs.c ****             return res < 0 ? LFS_CMP_LT : LFS_CMP_GT;
 165:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 166:SynaptiX_FDK/services/littlefs/lfs.c ****     }
 167:SynaptiX_FDK/services/littlefs/lfs.c **** 
 168:SynaptiX_FDK/services/littlefs/lfs.c ****     return LFS_CMP_EQ;
 169:SynaptiX_FDK/services/littlefs/lfs.c **** }
 170:SynaptiX_FDK/services/littlefs/lfs.c **** 
 171:SynaptiX_FDK/services/littlefs/lfs.c **** static int lfs_bd_crc(lfs_t *lfs,
 172:SynaptiX_FDK/services/littlefs/lfs.c ****         const lfs_cache_t *pcache, lfs_cache_t *rcache, lfs_size_t hint,
 173:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_block_t block, lfs_off_t off, lfs_size_t size, uint32_t *crc) {
 174:SynaptiX_FDK/services/littlefs/lfs.c ****     lfs_size_t diff = 0;
 175:SynaptiX_FDK/services/littlefs/lfs.c **** 
 176:SynaptiX_FDK/services/littlefs/lfs.c ****     for (lfs_off_t i = 0; i < size; i += diff) {
 177:SynaptiX_FDK/services/littlefs/lfs.c ****         uint8_t dat[8];
 178:SynaptiX_FDK/services/littlefs/lfs.c ****         diff = lfs_min(size-i, sizeof(dat));
 179:SynaptiX_FDK/services/littlefs/lfs.c ****         int err = lfs_bd_read(lfs,
 180:SynaptiX_FDK/services/littlefs/lfs.c ****                 pcache, rcache, hint-i,
 181:SynaptiX_FDK/services/littlefs/lfs.c ****                 block, off+i, &dat, diff);
 182:SynaptiX_FDK/services/littlefs/lfs.c ****         if (err) {
 183:SynaptiX_FDK/services/littlefs/lfs.c ****             return err;
 184:SynaptiX_FDK/services/littlefs/lfs.c ****         }
 185:SynaptiX_FDK/services/littlefs/lfs.c **** 
 186:SynaptiX_FDK/services/littlefs/lfs.c ****         *crc = lfs_crc(*crc, &dat, diff);
 187:SynaptiX_FDK/services/littlefs/lfs.c ****     }
 188:SynaptiX_FDK/services/littlefs/lfs.c **** 
 189:SynaptiX_FDK/services/littlefs/lfs.c ****     return 0;
 190:SynaptiX_FDK/services/littlefs/lfs.c **** }
