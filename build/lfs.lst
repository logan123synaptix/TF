3756:SynaptiX_FDK/services/littlefs/lfs.c **** 
3757:SynaptiX_FDK/services/littlefs/lfs.c ****     // write out everything beforehand, may be noop if rdonly
3758:SynaptiX_FDK/services/littlefs/lfs.c ****     int err = lfs_file_flush(lfs, file);
3759:SynaptiX_FDK/services/littlefs/lfs.c ****     if (err) {
