  31:SynaptiX_FDK/services/littlefs/lfs.c **** static inline void lfs_cache_drop(lfs_t *lfs, lfs_cache_t *rcache) {
  32:SynaptiX_FDK/services/littlefs/lfs.c ****     // do not zero, cheaper if cache is readonly or only going to be
  33:SynaptiX_FDK/services/littlefs/lfs.c ****     // written with identical data (during relocates)
  34:SynaptiX_FDK/services/littlefs/lfs.c ****     (void)lfs;
  35:SynaptiX_FDK/services/littlefs/lfs.c ****     rcache->block = LFS_BLOCK_NULL;
