  38:SynaptiX_FDK/services/littlefs/lfs.c **** static inline void lfs_cache_zero(lfs_t *lfs, lfs_cache_t *pcache) {
  39:SynaptiX_FDK/services/littlefs/lfs.c ****     // zero to avoid information leak
  40:SynaptiX_FDK/services/littlefs/lfs.c ****     memset(pcache->buffer, 0xff, lfs->cfg->cache_size);
  41:SynaptiX_FDK/services/littlefs/lfs.c ****     pcache->block = LFS_BLOCK_NULL;
  42:SynaptiX_FDK/services/littlefs/lfs.c **** }
