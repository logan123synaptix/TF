3716:SynaptiX_FDK/services/littlefs/lfs.c **** static lfs_soff_t lfs_file_seek_(lfs_t *lfs, lfs_file_t *file,
3717:SynaptiX_FDK/services/littlefs/lfs.c ****         lfs_soff_t off, int whence) {
