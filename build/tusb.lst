 226:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** 
 227:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** bool tu_edpt_claim(tu_edpt_state_t* ep_state, osal_mutex_t mutex) {
 228:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   (void) mutex;
 229:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** 
 230:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   // pre-check to help reducing mutex lock
 231:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   TU_VERIFY(ep_state->busy == 0);
 232:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   TU_VERIFY(ep_state->claimed == 0);
 233:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   (void) osal_mutex_lock(mutex, OSAL_TIMEOUT_WAIT_FOREVER);
 234:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** 
 235:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   // can only claim the endpoint if it is not busy and not claimed yet.
 236:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   bool const available = (ep_state->busy == 0) && (ep_state->claimed == 0);
 237:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   if (available) {
 238:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****     ep_state->claimed = 1;
 239:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   }
 240:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** 
 241:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   (void) osal_mutex_unlock(mutex);
 242:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   return available;
 243:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** }
 244:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** 
 245:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** bool tu_edpt_release(tu_edpt_state_t* ep_state, osal_mutex_t mutex) {
 246:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   (void) mutex;
 247:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   (void) osal_mutex_lock(mutex, OSAL_TIMEOUT_WAIT_FOREVER);
 248:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** 
 249:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   // can only release the endpoint if it is claimed and not busy
 250:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   bool const ret = (ep_state->claimed == 1) && (ep_state->busy == 0);
 251:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   if (ret) {
 252:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****     ep_state->claimed = 0;
 253:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   }
 254:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** 
 255:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   (void) osal_mutex_unlock(mutex);
 256:SynaptiX_FDK/lib/tinyusb/src/tusb.c ****   return ret;
 257:SynaptiX_FDK/lib/tinyusb/src/tusb.c **** }
