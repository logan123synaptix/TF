6956:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h **** {
6957:Drivers/STM32H5xx_HAL_Driver/Inc/stm32h5xx_ll_adc.h ****   /* Note: Write register with some additional bits forced to state reset     */
