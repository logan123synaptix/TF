  30:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****   ==============================================================================
  31:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****   [..]
  32:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****     The Timer Extended features include:
  33:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****     (#) Complementary outputs with programmable dead-time for :
  34:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****         (++) Output Compare
  35:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****         (++) PWM generation (Edge and Center-aligned Mode)
  36:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****         (++) One-pulse mode output
  37:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****     (#) Synchronization circuit to control the timer with external signals and to
  38:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****         interconnect several timers together.
  39:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****     (#) Break input to put the timer output signals in reset state or in a known state.
  40:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****     (#) Supports incremental (quadrature) encoder and hall-sensor circuitry for
  41:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****         positioning purposes
  42:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****     (#) In case of Pulse on compare, configure pulse length and delay
  43:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****     (#) Encoder index configuration
  44:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c **** 
  45:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****             ##### How to use this driver #####
  46:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****   ==============================================================================
  47:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****     [..]
  48:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****      (#) Initialize the TIM low level resources by implementing the following functions
  49:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****          depending on the selected feature:
  50:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****            (++) Hall Sensor output : HAL_TIMEx_HallSensor_MspInit()
  51:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c **** 
  52:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****      (#) Initialize the TIM low level resources :
  53:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****         (##) Enable the TIM interface clock using __HAL_RCC_TIMx_CLK_ENABLE();
  54:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****         (##) TIM pins configuration
  55:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****             (+++) Enable the clock for the TIM GPIOs using the following function:
  56:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****               __HAL_RCC_GPIOx_CLK_ENABLE();
  57:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****             (+++) Configure these TIM pins in Alternate function mode using HAL_GPIO_Init();
  58:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c **** 
  59:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****      (#) The external Clock can be configured, if needed (the default clock is the
  60:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****          internal clock from the APBx), using the following function:
  61:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****          HAL_TIM_ConfigClockSource, the clock configuration should be done before
  62:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****          any start function.
  63:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c **** 
  64:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****      (#) Configure the TIM in the desired functioning mode using one of the
  65:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****          initialization function of this driver:
  66:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****           (++) HAL_TIMEx_HallSensor_Init() and HAL_TIMEx_ConfigCommutEvent(): to use the
  67:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****                Timer Hall Sensor Interface and the commutation event with the corresponding
  68:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****                Interrupt and DMA request if needed (Note that One Timer is used to interface
  69:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****                with the Hall sensor Interface and another Timer should be used to use
  70:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****                the commutation event).
  71:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****      (#) In case of Pulse On Compare:
  72:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****            (++) HAL_TIMEx_OC_ConfigPulseOnCompare(): to configure pulse width and prescaler
  73:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c **** 
  74:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c **** 
  75:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****      (#) Activate the TIM peripheral using one of the start functions:
  76:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****            (++) Complementary Output Compare : HAL_TIMEx_OCN_Start(), HAL_TIMEx_OCN_Start_DMA(),
  77:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****                 HAL_TIMEx_OCN_Start_IT()
  78:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****            (++) Complementary PWM generation : HAL_TIMEx_PWMN_Start(), HAL_TIMEx_PWMN_Start_DMA(),
  79:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****                 HAL_TIMEx_PWMN_Start_IT()
  80:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****            (++) Complementary One-pulse mode output : HAL_TIMEx_OnePulseN_Start(), HAL_TIMEx_OnePul
  81:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****            (++) Hall Sensor output : HAL_TIMEx_HallSensor_Start(), HAL_TIMEx_HallSensor_Start_DMA()
  82:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****                 HAL_TIMEx_HallSensor_Start_IT().
  83:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c **** 
  84:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****   @endverbatim
  85:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****   ******************************************************************************
  86:Drivers/STM32H5xx_HAL_Driver/Src/stm32h5xx_hal_tim_ex.c ****   */
